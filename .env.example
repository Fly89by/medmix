# === MED.MIX OS Environment Variables ===

# App
APP_NAME=MED.MIX OS
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key

# Database
DATABASE_URL=postgresql+asyncpg://medmix:medmix_pass@localhost:5432/medmix_db

# JWT
JWT_SECRET_KEY=change-this-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=medmix
MINIO_SECRET_KEY=medmix_secret
MINIO_BUCKET=medmix-storage
MINIO_USE_SSL=false

# OpenAI (optional - use simulation mode if empty)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Maps (optional - simulation mode if empty)
GOOGLE_MAPS_API_KEY=

# Email / SMTP (optional - notifications disabled if empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
